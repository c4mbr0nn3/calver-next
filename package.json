{
    "name": "calver-next",
    "version": "25.6.0",
    "description": "Calendar based software versioning library with custom format string support. Fork of node-calver.",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
        "calver-next": "./dist/cli.js"
    },
    "scripts": {
        "build": "pkgroll --target=es2020 --target=node16 --clean-dist",
        "format": "prettier --write --ignore-unknown .",
        "lint": "eslint .",
        "test": "vitest run",
        "prepare": "husky"
    },
    "exports": {
        "require": {
            "types": "./dist/index.d.cts",
            "default": "./dist/index.cjs"
        },
        "import": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist/*",
        "LICENSE",
        "package.json"
    ],
    "lint-staged": {
        "**/*": "prettier --write --ignore-unknown ."
    },
    "browserslist": [
        "defaults",
        "> 0.1%",
        "ie 10",
        "not ie 9"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/c4mbr0nn3/calver-next.git"
    },
    "keywords": [
        "calver",
        "calendar",
        "versioning",
        "semver",
        "calver-format",
        "calver-next",
        "fork"
    ],
    "contributors": [
        {
            "name": "Murat Gözel",
            "email": "murat@gozel.com.tr",
            "url": "https://gozel.com.tr"
        },
        {
            "name": "c4mbr0nn3",
            "url": "https://github.com/c4mbr0nn3"
        }
    ],
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/c4mbr0nn3/calver-next/issues"
    },
    "homepage": "https://github.com/c4mbr0nn3/calver-next#readme",
    "devDependencies": {
        "@commitlint/cli": "^19.3.0",
        "@commitlint/config-conventional": "^19.2.2",
        "@commitlint/types": "^19.0.3",
        "@eslint/js": "^9.3.0",
        "eslint": "^9.3.0",
        "husky": "^9.1.7",
        "lint-staged": "^15.2.2",
        "pkgroll": "^2.27.1",
        "prettier": "^3.8.5",
        "typescript": "^5.4.5",
        "typescript-eslint": "^7.9.0",
        "vitest": "^1.6.0"
    },
    "dependencies": {
        "commander": "^12.0.0"
    }
}
